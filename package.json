{
  "name": "poke-code",
  "version": "0.2.0",
  "description": "Claude Code-style terminal CLI for Poke AI",
  "type": "module",
  "bin": {
    "poke-code": "./dist/bin/poke.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/bin/poke.js",
    "lint": "biome check src/ bin/ test/",
    "lint:fix": "biome check --write src/ bin/ test/",
    "format": "biome format --write src/ bin/ test/",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "cron-parser": "^5.5.0",
    "diff": "^8.0.4",
    "glob": "^13.0.6",
    "ink": "^6.8.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^8.0.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/yargs": "^17.0.35",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
